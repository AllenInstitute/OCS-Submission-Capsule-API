{
  // Main configuration.
  // Edit this file to add or change alignment and post-alignment commands.
  //
  // How to add a new alignment command:
  // 1. Go to workflows.<MODALITY>.alignment_command_configs
  // 2. Add a new command config object
  // 3. Set match.library_preps and optional match.organisms
  // 4. Set command and arguments
  // 5. Put more specific command configs before more general command configs
  //
  // Argument values support these placeholders:
  // - {reference_name}
  // - {load_name}
  // - {email}
  // - {chemistry}
  // - {probe_set}
  // - {execution_vcpus}
