  "probe_sets_by_organism": {
    "mouse": {
      "10xV4_FX4": "mouse_10x_mm10-egfp-mscarlet-vbc_chromium_v1.1_cellflex_probe_set",
      "10xV4_FX16": "mouse_10x_mm10-flex-custom-v1_chromium_v1.1_cellflex_probe_set"
    }
  },
  "chemistry_by_library_prep": {
    "10xV3.1D": "SC3Pv3",
    "10xRseq_Mult_noATAC": "ARC-v1",
    "10xV3.1_HT": "SC3Pv3HT",
    "10xV4": "SC3Pv4",
    "10Xv2": "SC3Pv2",
    "10Xv3.1": "SC3Pv3"
  },
  "workflows": {
    "MTX": {
      "alignment_command_configs": [
        {
          "name": "default",
          "match": {
            "library_preps": [
              "*"
            ],
            "organisms": [
              "*"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-arc"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
              "value": "{reference_name}"
            },
            {
              "flag": "--asset-name",
              "value": "cellranger-arc"
            },
            {
              "flag": "--load-names",
              "value": "{load_name}"
            },
            {
              "flag": "--notify-on",
              "value": "FAILED"
            },
            {
              "flag": "--notify",
              "value": "{email}"
            }
          ],
          "spacing": 180
        }
      ],
      "post_alignment": {
        "command": [
          "ocs",
          "fastqs",
          "postalign",
          "tenx-arc"
        ],
        "arguments": [
          {
            "flag": "--asset-name",
            "value": "10x_multiome_qc"
          },
          {
            "flag": "--asset-tag",
            "value": "1.0.0"
          },
          {
            "flag": "--load-names",
            "value": "{load_name}"
          },
          {
            "flag": "--notify-on",
            "value": "FAILED"
          },
          {
            "flag": "--notify",
            "value": "{email}"
          }
        ],
        "spacing": 60
      }
    },
    "RTX": {
      "alignment_command_configs": [
        {
          "name": "standard",
          "match": {
            "library_preps": [
              "10xV3.1D",
              "10xRseq_Mult_noATAC",
              "10xV3.1_HT",
              "10Xv3.1",
              "10Xv2"
            ],
            "organisms": [
              "*"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-rnaseq"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
              "value": "{reference_name}"
            },
            {
              "flag": "--asset-name",
              "value": "cellranger-rnaseq"
            },
            {
              "flag": "--load-names",
              "value": "{load_name}"
            },
            {
              "flag": "--asset-tag",
              "value": "latest"
            },
            {
              "flag": "--cellranger-addopts",
              "value": "--chemistry {chemistry} --include-introns"
            },
            {
              "flag": "--notify-on",
              "value": "FAILED"
            },
            {
              "flag": "--notify",
              "value": "{email}"
            }
          ],
          "spacing": 180
        },
        {
          "name": "multi",
          "match": {
            "library_preps": [
              "10xV3.1_HT_CP",
              "10xV3.1_HT_CP-BC"
            ],
            "organisms": [
              "*"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-rnaseq-multi"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
              "value": "{reference_name}"
            },
            {
              "flag": "--asset-name",
              "value": "cellranger-multi"
            },
            {
              "flag": "--load-names",
              "value": "{load_name}"
            },
            {
              "flag": "--asset-tag",
              "value": "latest"
            },
            {
              "flag": "--cellranger-addopts",
              "value": "--include-introns"
            },
            {
              "flag": "--notify-on",
              "value": "FAILED"
            },
            {
              "flag": "--notify",
              "value": "{email}"
            }
          ],
          "spacing": 180
        },
        {
          "name": "10xV4_PX",
          "match": {
            "library_preps": [
              "10xV4_PX"
            ],
            "organisms": [
              "*"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-rnaseq-multi"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
              "value": "{reference_name}"
            },
            {
              "flag": "--asset-name",
              "value": "cellranger-multi"
            },
            {
              "flag": "--load-names",
              "value": "{load_name}"
            },
            {
              "flag": "--asset-tag",
              "value": "9.0.1"
            },
            {
              "flag": "--cellranger-addopts",
              "value": "--create-bam=TRUE"
            },
            {
              "flag": "--notify-on",
              "value": "FAILED"
            },
            {
              "flag": "--notify",
              "value": "{email}"
            }
          ],
          "spacing": 180
        },
        {
          "name": "10xV4",
          "match": {
            "library_preps": [
              "10xV4"
            ],
            "organisms": [
              "*"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-rnaseq"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
              "value": "{reference_name}"
            },
            {
              "flag": "--asset-name",
              "value": "cellranger-rnaseq"
            },
            {
              "flag": "--load-names",
              "value": "{load_name}"
            },
            {
              "flag": "--asset-tag",
              "value": "8.0.1"
            },
            {
              "flag": "--cellranger-addopts",
              "value": "--chemistry {chemistry}"
            },
            {
              "flag": "--notify-on",
              "value": "FAILED"
            },
            {
              "flag": "--notify",
              "value": "{email}"
            }
          ],
          "spacing": 180
        },
        {
          "name": "10xV4_FX4",
          "match": {
            "library_preps": [
              "10xV4_FX4",
              "10xV4_FX4-cps"
            ],
            "organisms": [
              "*"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-rnaseq-multi"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
              "value": "{reference_name}"
            },
            {
              "flag": "--asset-name",
              "value": "cellranger-multi"
            },
            {
              "flag": "--load-names",
              "value": "{load_name}"
            },
            {
              "flag": "--asset-tag",
              "value": "9.0.1"
            },
            {
              "flag": "--cellflex-probe-set-name",
              "value": "{probe_set}"
            },
            {
              "flag": "--cellranger-addopts",
              "value": "--create-bam=true"
            },
            {
              "flag": "--execution-vcpus",
              "value": "{execution_vcpus}"
            },
            {
              "flag": "--notify-on",
              "value": "FAILED"
            },
            {
              "flag": "--notify",
              "value": "{email}"
            }
          ],
          "execution_vcpus": 180,
