  "job_settings": {
    "limit": 100
  },
  "status_mappings": {
    "ingest_complete": [
      "INGEST_COMPLETE",
      "COMPLETED",
      "ARCHIVED"
    ],
    "alignment_complete": [
      "COMPLETED",
      "ARCHIVED"
    ],
    "post_alignment_complete": [
