{
  // Main configuration.
  // Edit this file to add or change alignment and post-alignment commands.
  //
  // Alignment — workflows.<MODALITY>.alignment_command_configs
  //   1. Add a config object with name, match, command, arguments, and spacing.
  //   2. In match, set library_preps and optionally organisms.
  //      Omit organisms to match any organism, or list specific names to restrict.
  //   3. Put more specific configs before general ones — first match wins.
  //
  // Post-alignment QC — workflows.<MODALITY>.post_alignment_command_configs
  //   1. Add a config object with name, match, command, arguments, and spacing.
  //   2. In match, set library_preps to the specific library preps that run QC.
  //   3. Put more specific configs before general ones — first match wins.
  //
  // Argument values support these placeholders:
  // - {reference_name}
  // - {load_name}
  // - {email}
  // - {chemistry}
  // - {probe_set}
  // - {execution_vcpus}
  "references": {
