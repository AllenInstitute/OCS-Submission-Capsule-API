  "job_settings": {
    "limit": 100,
    // When the limit is reached, wait this many hours before re-checking capacity
    // instead of skipping the job. Default 1.
    "poll_interval_hours": 1
  },
  // List of literal OCS completed status labels.
  "status_mappings": {
    "ingest_complete": [
      "INGEST_COMPLETE",
      "COMPLETED",
      "ARCHIVED"
    ],
    "alignment_complete": [
      "COMPLETED",
      "ARCHIVED"
    ],
    "post_alignment_complete": [
      "COMPLETED",
      "ARCHIVED"
    ]
  }
}
