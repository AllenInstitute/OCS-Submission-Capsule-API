  "workflows": {
    "MTX": {
      "alignment_command_configs": [
        {
          "name": "10xMultX_GEX",
          "match": {
            "library_preps": [
              "10xMultX_GEX"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-arc"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
              "value": "{reference_name}"
            },
            {
              "flag": "--asset-name",
              "value": "cellranger-arc"
            },
            {
              "flag": "--asset-tag",
              "value": "2.2.0"
            },
            {
              "flag": "--load-names",
              "value": "{load_name}"
            },
            {
              "flag": "--notify-on",
              "value": "FAILED"
            },
            {
              "flag": "--notify",
              "value": "{email}"
            }
          ],
          "spacing": 180
        },
        {
          "name": "standard",
          "match": {
            "library_preps": [
              "10xRSeq_Mult"
            ]
          },
          "command": [
            "ocs",
            "fastqs",
            "align",
            "tenx-arc"
          ],
          "arguments": [
            {
              "flag": "--reference-names",
